set number
set NERDTree

" Options
set clipboard+=unnamed
set timeoutlen=500
set ignorecase
set smartcase

" Mappings
let mapleader = " "

" IntelliJ

" manipulation
vmap <leader>c <Action>(CommentByBlockComment)
nmap <Leader>rn <Action>(RenameElement)

" search and information
nmap <leader>u <Action>(FindUsages)
nmap <Leader>or <Action>(ManageRecentProjects)
nmap <leader>h <Action>(ShowHoverInfo)

" navigation
nmap <leader>i <Action>(GotoImplementation)
nmap <leader>d <Action>(GotoDeclaration)
nmap <c-o> <Action>(Back)
nmap <c-i> <Action>(Forward)
nmap <Leader>e <Action>(SelectInProjectView)
nmap <Leader>n <Action>(GotoNextError)

" version control
nmap <leader>j <Action>(VcsShowNextChangeMarker)
nmap <leader>k <Action>(VcsShowPrevChangeMarker)
nmap <leader>z <Action>(Vcs.RollbackChangedLines)

" debugging
nmap <leader>rr <Action>(Resume)
nmap <leader>ra <Action>(Debug)
nmap <leader>rs <Action>(Stop)
nmap <leader>b <Action>(ToggleLineBreakpoint)
nmap <leader>rc <Action>(RunToCursor)
nmap <leader>rt <Action>(RunClass)

" Norwegian keyboard
nmap æ {
nmap ø }
nmap 0 ^
nmap @ $
nnoremap zC zM
nnoremap zO zR
