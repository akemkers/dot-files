set number
set NERDTree

" Options
set clipboard+=unnamed
set timeoutlen=2000
set ignorecase
set smartcase

" Mappings
let mapleader = " "

nnoremap <leader>rc :source ~/.ideavimrc<CR>

" IntelliJ

" manipulation
vmap <leader>cc <Action>(CommentByBlockComment)
nmap <Leader>cr <Action>(RenameElement)
nmap <leader>cf <Action>(ReformatCode)
nmap <leader>ca <Action>(ShowIntentionActions)
nmap <leader>co <Action>(OptimizeImports)

" search and information
nmap K <Action>(ShowHoverInfo)
nmap <Leader>or <Action>(ManageRecentProjects)
nmap <leader>sg <Action>(FindInPath)
nmap <leader>, <Action>(RecentFiles)
nmap <leader>ff <Action>(SearchEverywhere)
nmap <leader><leader> <Action>(SearchEverywhere)


" navigation
nmap gi <Action>(GotoImplementation)
nmap gd <Action>(GotoDeclaration)
nmap gr <Action>(FindUsages)
nmap <c-o> <Action>(Back)
nmap <c-i> <Action>(Forward)
nmap <Leader>e <Action>(SelectInProjectView)
nmap <Leader>n <Action>(GotoNextError)

" version control
nmap <leader>ghn <Action>(VcsShowNextChangeMarker)
nmap <leader>ghp <Action>(VcsShowPrevChangeMarker)
nmap <leader>ghr <Action>(Vcs.RollbackChangedLines)
nmap <leader>ghd <Action>(Compare.SameVersion)
nmap <leader>ghh <Action>(Git.CompareWithBranch)

" debugging
nmap <leader>dr <Action>(Resume)
nmap <leader>da <Action>(Debug)
nmap <leader>ds <Action>(Stop)
nmap <leader>db <Action>(ToggleLineBreakpoint)
nmap <leader>dc <Action>(RunToCursor)

" runTest
nmap <leader>tr <Action>(RunClass)

" tabs
nmap <leader>sv <Action>(SplitVertically)
nmap <leader>sh <Action>(SplitHorizontally)
nmap <leader>pt <Action>(PinActiveEditorTab)
nmap <leader>pc <Action>(CloseAllUnpinnedEditors)
nmap H <Action>(PreviousTab)
nmap L <Action>(NextTab)
nmap <c-h> <Action>(PrevSplitter)
nmap <c-l> <Action>(NextSplitter)

" Zen 
nmap <leader>z <Action>(HideAllWindows)

" Indent and keep text selected
vnoremap > >gv
vnoremap < <gv

